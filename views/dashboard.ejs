<%- include("partials/header") %>

<main class="dashboard-page">
    <section class="dashboard-hero">
        <div>
            <p class="eyebrow">Student dashboard</p>
            <h1>Welcome back, <%= user.name || "Student" %>.</h1>
            <p class="dashboard-subtitle">Keep your skills, certifications and achievements moving forward.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" href="/addSkill">
                <span aria-hidden="true">+</span> Add Skill
            </a>

            <a class="btn btn-light dashboard-add" href="/addSubmission">
                <span aria-hidden="true">+</span> Add Submission
            </a>
        </div>
    </section>

    <section class="dashboard-stats" aria-label="Dashboard summary">

        <article class="stat-card stat-card-featured">
            <div class="stat-icon" aria-hidden="true">&#9733;</div>
            <div>
                <span class="stat-value"><%= skills.length %></span>
                <span class="stat-label">Skills</span>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#128193;</div>
            <div>
                <span class="stat-value"><%= submissions.length %></span>
                <span class="stat-label">Portfolio Entries</span>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#10003;</div>
            <div>
                <span class="stat-value"><%= submissions.filter(submission => submission.status === "Verified").length %></span>
                <span class="stat-label">Verified</span>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#8599;</div>
            <div>
                <span class="stat-value"><%= submissions.filter(submission => submission.status === "Pending").length %></span>
                <span class="stat-label">Pending</span>
            </div>
        </article>

    </section>

    <!-- My Skills -->
    <section class="skills-panel" aria-labelledby="skills-heading">

        <div class="panel-heading">
            <div>
                <p class="eyebrow">Your skills</p>
                <h2 id="skills-heading">My Skills</h2>
            </div>

            <a href="/search" class="dashboard-link">
                Search skills →
            </a>
        </div>

        <% if (skills.length === 0) { %>

            <div class="dashboard-empty">
                <h3>No skills added yet</h3>
                <p>Add your first skill to build your portfolio.</p>

                <a class="btn btn-primary" href="/addSkill">
                    Add Skill
                </a>
            </div>

        <% } else { %>

            <div class="skill-grid">

                <% skills.forEach(skill => { %>

                    <article class="skill-card">

                        <div class="skill-card-top">
                            <span class="skill-category">
                                <%= skill.category %>
                            </span>

                            <span class="skill-status">
                                <%= skill.status %>
                            </span>
                        </div>

                        <h3><%= skill.skill_name %></h3>

                        <p><%= skill.description || "No description." %></p>

                        <p class="text-muted">
                            Started:
                            <%= new Date(skill.dateStarted).toLocaleDateString() %>
                        </p>

                        <a href="/editSkill?id=<%= skill.id %>">
                            View details →
                        </a>

                    </article>

                <% }) %>

            </div>

        <% } %>

    </section>

    <!-- My Submission Status -->
    <section class="skills-panel" aria-labelledby="submission-status-heading">

        <div class="panel-heading">
            <div>
                <p class="eyebrow">Private to you</p>
                <h2 id="submission-status-heading">My Submission Status</h2>
            </div>
        </div>

        <% if (submissions.length === 0) { %>
            <div class="dashboard-empty">
                <h3>No portfolio submissions yet</h3>
                <p>Your submission updates will appear here after you submit a portfolio entry.</p>
            </div>
        <% } else { %>
            <div class="skill-grid">
                <% submissions.forEach(submission => { %>
                    <article class="skill-card">
                        <div class="skill-card-top">
                            <span class="skill-category"><%= submission.category || "General" %></span>
                            <span class="skill-status"><%= submission.status || "Pending" %></span>
                        </div>
                        <h3><%= submission.title %></h3>
                        <p><%= submission.description || "No description added yet." %></p>
                        <a href="/editPortfolio/<%= submission.portfolioId %>">View details <span aria-hidden="true">&rarr;</span></a>
                        <form action="/deletePortfolio/<%= submission.portfolioId %>" method="POST" class="mt-3" onsubmit="return confirm('Are you sure you want to delete this portfolio entry?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>
</main>

<%- include("partials/footer") %>
