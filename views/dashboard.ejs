<%- include("partials/header") %>

<main class="dashboard-page">
    <section class="dashboard-hero">
        <div>
            <p class="eyebrow">Student dashboard</p>
            <h1>Welcome back, <%= user.name || "Student" %>.</h1>
            <p class="dashboard-subtitle">Keep your skills, certifications and achievements moving forward.</p>
        </div>
        <a class="btn btn-light dashboard-add" href="/addSkill">
            <span aria-hidden="true">+</span> Add new skill
        </a>
    </section>

    <% if (updated) { %>
        <div class="alert alert-success mt-3" role="alert">
            Entry updated successfully.
        </div>
    <% } %>

    <section class="dashboard-stats" aria-label="Portfolio summary">
        <article class="stat-card stat-card-featured">
            <div class="stat-icon" aria-hidden="true">&#9733;</div>
            <div>
                <span class="stat-value"><%= entries.length %></span>
                <span class="stat-label">Entries tracked</span>
            </div>
        </article>
        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#10003;</div>
            <div>
                <span class="stat-value"><%= entries.filter(entry => entry.status === "Verified").length %></span>
                <span class="stat-label">Verified</span>
            </div>
        </article>
        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#8599;</div>
            <div>
                <span class="stat-value"><%= entries.filter(entry => entry.status === "Pending").length %></span>
                <span class="stat-label">Pending review</span>
            </div>
        </article>
        <article class="stat-card">
            <div class="stat-icon" aria-hidden="true">&#127942;</div>
            <div>
                <span class="stat-value"><%= entries.filter(entry => entry.category === "Project").length %></span>
                <span class="stat-label">Projects</span>
            </div>
        </article>
    </section>

    <section class="skills-panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow"><%= user.role === "admin" ? "All submissions" : "Your portfolio" %></p>
                <h2><%= user.role === "admin" ? "Portfolio management" : "My portfolio" %></h2>
            </div>
            <a href="/search" class="dashboard-link">Search skills <span aria-hidden="true">&rarr;</span></a>
        </div>

        <% if (entries.length === 0) { %>
            <div class="dashboard-empty">
                <div class="empty-mark" aria-hidden="true">&#9733;</div>
                <h3>Your portfolio starts here</h3>
                <p>Add your first skill and track your learning progress, projects and certifications in one place.</p>
                <a class="btn btn-dark" href="/addSkill">Add your first skill</a>
            </div>
        <% } else { %>
            <div class="skill-grid">
                <% entries.forEach(entry => { %>
                    <article class="skill-card">
                        <div class="skill-card-top">
                            <span class="skill-category"><%= entry.category || "General" %></span>
                            <span class="skill-status"><%= entry.status || "Pending" %></span>
                        </div>
                        <h3><%= entry.title %></h3>
                        <p><%= entry.description || "No description added yet." %></p>
                        <% if (user.role === "admin") { %>
                            <p class="text-muted small mb-2">Owner: <%= entry.studentName %></p>
                        <% } %>
                        <a href="/editPortfolio/<%= entry.portfolioId %>">Edit entry <span aria-hidden="true">&rarr;</span></a>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>
</main>

<%- include("partials/footer") %>
