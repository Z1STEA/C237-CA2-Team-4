<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>SkillSync</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/css/style.css">

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark skillsync-navbar">

    <div class="container">

        <a class="navbar-brand fw-bold" href="/">

            <span aria-hidden="true">&#127942;</span> SkillSync

        </a>

        <button
            class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbar"
            aria-controls="navbar"
            aria-expanded="false"
            aria-label="Toggle navigation">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div
            class="collapse navbar-collapse"
            id="navbar">

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">

                    <a
                        class="nav-link"
                        href="/">

                        Home

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link"
                        href="/dashboard">

                        Dashboard

                    </a>

                </li>

                <li class="nav-item">

                    <a
                        class="nav-link"
                        href="/addSkill">

                        Add Skill

                    </a>

                </li>

                <!-- =========================================================
                Part F Addition (Wei Han)
                Navigation Link - Search
                ========================================================= -->

                <li class="nav-item">

                    <a
                        class="nav-link"
                        href="/search">

                        Search

                    </a>

                </li>

                <!-- End Part F Addition -->

                <% if (user && user.role === "admin") { %>

                    <li class="nav-item">

                        <a class="nav-link" href="/admin/dashboard">Manage Submissions</a>

                    </li>

                <% } %>

                <% if (user) { %>

                    <li class="nav-item">

                        <a
                            class="nav-link"
                            href="/logout">

                            Logout

                        </a>

                    </li>

                <% } else { %>

                    <li class="nav-item">

                        <a
                            class="nav-link"
                            href="/login">

                            Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a
                            class="nav-link"
                            href="/register">

                            Register

                        </a>

                    </li>

                <% } %>

            </ul>

        </div>

    </div>

</nav>

<div class="container mt-4">