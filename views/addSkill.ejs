<%- include("partials/header") %>

<h2>Add Skill</h2>

<hr>

<% if (error) { %>

<div class="alert alert-danger">
    <%= error %>
</div>

<% } %>


<% if (success) { %>

<div class="alert alert-success">
    <%= success %>
</div>

<% } %>



<form action="/addSkill" method="POST">


    <div class="mb-3">

        <label for="skillName" class="form-label">
            Skill Name
        </label>

        <input
            type="text"
            id="skillName"
            name="skillName"
            class="form-control"
            value="<%= formData.skillName || '' %>"
            required>

    </div>



    <div class="mb-3">

        <label for="category" class="form-label">
            Category
        </label>


        <select
            id="category"
            name="category"
            class="form-select"
            required>


            <option value="">
                Select Category
            </option>


            <option value="Technology"
            <%= formData.category === "Technology" ? "selected" : "" %>>
                Technology
            </option>


            <option value="Design"
            <%= formData.category === "Design" ? "selected" : "" %>>
                Design
            </option>


            <option value="Soft Skills"
            <%= formData.category === "Soft Skills" ? "selected" : "" %>>
                Soft Skills
            </option>


            <option value="Language"
            <%= formData.category === "Language" ? "selected" : "" %>>
                Language
            </option>


            <option value="Sports"
            <%= formData.category === "Sports" ? "selected" : "" %>>
                Sports
            </option>


            <option value="Others"
            <%= formData.category === "Others" ? "selected" : "" %>>
                Others
            </option>


        </select>

    </div>




    <div class="mb-3">

        <label for="proficiencyLevel" class="form-label">
            Proficiency Level
        </label>


        <select
            id="proficiencyLevel"
            name="proficiencyLevel"
            class="form-select"
            required>


            <option value="">
                Select Level
            </option>


            <option value="Beginner"
            <%= formData.proficiencyLevel === "Beginner" ? "selected" : "" %>>
                Beginner
            </option>


            <option value="Intermediate"
            <%= formData.proficiencyLevel === "Intermediate" ? "selected" : "" %>>
                Intermediate
            </option>


            <option value="Advanced"
            <%= formData.proficiencyLevel === "Advanced" ? "selected" : "" %>>
                Advanced
            </option>


        </select>

    </div>


    <div class="mb-3">

        <label for="description" class="form-label">
            Description
        </label>


        <textarea
            id="description"
            name="description"
            class="form-control"
            rows="4"
            placeholder="Describe the skill"><%= formData.description || "" %></textarea>


    </div>


    <div class="mb-3">

        <label for="dateStarted" class="form-label">
            Date Started
        </label>


        <input
            type="date"
            id="dateStarted"
            name="dateStarted"
            class="form-control"
            value="<%= formData.dateStarted || '' %>"
            required>


    </div>

    <button type="submit" class="btn btn-success">
        Add Skill
    </button>

</form>


<%- include("partials/footer") %>