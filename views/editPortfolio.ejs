<%- include("partials/header") %>

<h2>Edit Portfolio Entry</h2>

<hr>

<% if (typeof errors !== "undefined" && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(function(error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<% if (entry) { %>

<form action="/editPortfolio/<%= entry.portfolioId %>" method="POST">

    <div class="mb-3">

        <label>Student Name</label>

        <input
            type="text"
            class="form-control"
            value="<%= entry.studentName %>"
            disabled>

    </div>

    <div class="mb-3">

        <label>Title</label>

        <input
            type="text"
            name="title"
            class="form-control"
            value="<%= entry.title %>"
            maxlength="150"
            required>

    </div>

    <div class="mb-3">

        <label>Category</label>

        <select name="category" class="form-select" required>
            <% categories.forEach(function(cat) { %>
                <option value="<%= cat %>" <%= entry.category === cat ? "selected" : "" %>>
                    <%= cat %>
                </option>
            <% }); %>
        </select>

    </div>

    <div class="mb-3">

        <label>Description</label>

        <textarea
            name="description"
            class="form-control"
            maxlength="2000"
            rows="4"><%= entry.description || '' %></textarea>

    </div>

    <div class="mb-3">

        <label>Verification Status</label>

        <% if (isAdmin) { %>

            <select name="status" class="form-select">
                <% statuses.forEach(function(s) { %>
                    <option value="<%= s %>" <%= entry.status === s ? "selected" : "" %>>
                        <%= s %>
                    </option>
                <% }); %>
            </select>

        <% } else { %>

            <div>
                <span class="badge <%= entry.status === 'Verified' ? 'bg-success' : entry.status === 'Rejected' ? 'bg-danger' : 'bg-secondary' %>">
                    <%= entry.status %>
                </span>
            </div>

            <% if (entry.status === "Verified" || entry.status === "Rejected") { %>
                <small class="text-muted d-block mt-1">
                    Editing this entry will reset it to "Pending" until an admin reviews it again.
                </small>
            <% } %>

        <% } %>

    </div>

    <% if (entry.updatedAt) { %>
        <p class="text-muted small">
            Last updated: <%= new Date(entry.updatedAt).toLocaleString() %>
        </p>
    <% } %>

    <button class="btn btn-warning" type="submit">

        Update Entry

    </button>

    <a href="/dashboard" class="btn btn-secondary">

        Cancel

    </a>

</form>

<% } %>

<%- include("partials/footer") %>
